# =========================================================================
# InboxPilot AI - Root Environment Configurations
# Copy this file to .env and configure keys.
# =========================================================================

# Database & Redis Settings
DATABASE_URL=postgresql+asyncpg://postgres:password@postgres:5432/inboxpilot
REDIS_URL=redis://redis:6379/0

# App Keys
SECRET_KEY=generate_a_random_jwt_secret_key_here
ENCRYPTION_KEY=generate_a_fernet_32_byte_key_here

# AI Credentials
OPENAI_API_KEY=your_openai_api_key

# OAuth Google Integration
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# OAuth Microsoft Outlook Integration
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common

# NextAuth Settings (Frontend)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your_nextauth_secret_key_here
NEXT_PUBLIC_API_URL=http://localhost:8000
