APP_ENV=development
SECRET_KEY=generate_a_random_jwt_secret_key_here
# Generate a valid 32-byte Fernet key, e.g. using python: `import cryptography.fernet; print(cryptography.fernet.Fernet.generate_key().decode())`
ENCRYPTION_KEY=
ALLOWED_ORIGINS=http://localhost:3000

DATABASE_URL=postgresql+asyncpg://postgres:password@postgres:5432/inboxpilot
REDIS_URL=redis://redis:6379/0

OPENAI_API_KEY=your_openai_api_key
OPENAI_CHAT_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
